# Kodee backend configuration
DATABASE_URL="file:./dev.db"
JWT_SECRET="change-me-to-a-long-random-string"
PORT=4000

# Days after invoice issue that payment is due (issued on the 1st).
PAYMENT_WINDOW_DAYS=5

# --- SMS (Africa's Talking). Leave blank to log messages to console instead. ---
AT_USERNAME=""
AT_API_KEY=""
AT_SENDER_ID="KODEE"

# Set to "false" to disable the monthly cron (useful in dev).
ENABLE_SCHEDULER="true"
