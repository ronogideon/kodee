# ── Kodee backend configuration ─────────────────────────────────────────────

# Postgres. On Railway, add the Postgres plugin and reference it:
#   DATABASE_URL=${{Postgres.DATABASE_URL}}
# Locally, either run `railway run npm run dev` (injects Railway's DATABASE_URL)
# or point at a local Postgres, e.g.:
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/kodee?schema=public"

# Long random string. On Railway set this per-service (or share via a group).
JWT_SECRET="change-me-to-a-long-random-string"

# Railway injects PORT automatically; keep 4000 for local dev.
PORT=4000

# Comma-separated list of allowed frontend origins for CORS.
# Leave blank to allow all (dev only). Wildcards cover per-landlord subdomains:
#   CORS_ORIGINS="https://kodee.app,https://*.kodee.app,https://admin.kodee.app"
CORS_ORIGINS=""

# A superadmin account is guaranteed at boot (created if none exists).
# Defaults: admin@kodee.app / kodee1234 — override in production:
SUPERADMIN_EMAIL=""
SUPERADMIN_PASSWORD=""

# Days after invoice issue that payment is due (issued on the 1st).
PAYMENT_WINDOW_DAYS=5

# ── SMS (Africa's Talking). Leave blank to log messages to console instead. ──
AT_USERNAME=""
AT_API_KEY=""
AT_SENDER_ID="KODEE"

# Set to "false" to disable the monthly cron.
ENABLE_SCHEDULER="true"
